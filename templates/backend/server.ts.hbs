import express from 'express';
import cors from 'cors';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import {
  createAgentsRouter,
  createKpisRouter,
  createTelemetryRouter,
  createThemeRouter,
  createSkynetProxy,
} from '@sidequestteams/mission-control-sdk/backend';
import { SkynetClient } from '@sidequestteams/mission-control-sdk/skynet';
import { KPI_REGISTRY, getKpisForRolePacks } from '@sidequestteams/mission-control-sdk/kpis';

const PORT = process.env.MC_PORT ?? 4100;
const MANIFEST_PATH = process.env.RUNTIME_MANIFEST_PATH ?? resolve('../../runtime-manifest.json');

// Load runtime manifest team block
const manifest = JSON.parse(readFileSync(MANIFEST_PATH, 'utf-8'));
const teamBlock = manifest.team;

// Initialize Skynet client from manifest connectivity
const skynetClient = new SkynetClient({
  wsUrl: teamBlock?.connectivity?.skynet?.ws_url ?? 'ws://skynet:9100',
  httpUrl: teamBlock?.connectivity?.skynet?.http_url ?? 'http://skynet:9100',
});

const app = express();
app.use(cors());
app.use(express.json());

// Serve manifest team block
app.get('/api/manifest', (_req, res) => {
  res.json({ team: teamBlock });
});

// ── Agents routes ──────────────────────────────────────────────────────
const agentsRouter = express.Router();
createAgentsRouter({
  async getAgents() {
    return skynetClient.httpGet('/agents');
  },
  async getAgent(id: string) {
    return skynetClient.httpGet(`/agents/${id}`);
  },
  async resetAgent(id: string) {
    return skynetClient.sendCommand({ type: 'reset', target: id });
  },
})(agentsRouter);
app.use('/api/agents', agentsRouter);

// ── KPI routes ─────────────────────────────────────────────────────────
const kpisRouter = express.Router();
createKpisRouter({
  async getKpis(rolePacks) {
    const packs = rolePacks ?? teamBlock?.role_packs ?? [];
    const definitions = getKpisForRolePacks(packs);
    return definitions.map((d) => ({
      id: d.id,
      value: 0,
      freshness: 'mock' as const,
      source: 'sdk-default',
    }));
  },
  async getKpi(id: string) {
    const definition = KPI_REGISTRY.find((d) => d.id === id);
    if (!definition) return null;
    return { id, value: 0, freshness: 'mock' as const, source: 'sdk-default' };
  },
  getRegistry() {
    return KPI_REGISTRY;
  },
})(kpisRouter);
app.use('/api/productivity/kpis', kpisRouter);

// ── Telemetry routes ───────────────────────────────────────────────────
const telemetryRouter = express.Router();
createTelemetryRouter({
  async getOverallMetrics() {
    return skynetClient.httpGet('/metrics');
  },
  async getAgentTimeSeries(agentId: string, hours = 24) {
    return skynetClient.httpGet(`/agents/${agentId}/timeseries?hours=${hours}`);
  },
})(telemetryRouter);
app.use('/api/telemetry', telemetryRouter);

// ── Theme route ────────────────────────────────────────────────────────
const themeRouter = express.Router();
createThemeRouter({
  async getTeamBlock() {
    return teamBlock ?? null;
  },
})(themeRouter);
app.use('/api/theme', themeRouter);

// ── SSE proxy for Skynet events ────────────────────────────────────────
app.use('/api/events', createSkynetProxy(skynetClient));

app.listen(PORT, () => {
  console.log(`[{{teamSlug}}] Mission Control backend listening on :${PORT}`);
});
