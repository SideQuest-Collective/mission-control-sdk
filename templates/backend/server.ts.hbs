import express from 'express';
import cors from 'cors';
import { createServer } from 'node:http';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { WebSocketServer } from 'ws';
import {
  createAgentsRouter,
  createKpisRouter,
  createTelemetryRouter,
  createThemeRouter,
  createSkynetProxy,
  createTasksRouter,
  createActivityRouter,
  createCostsRouter,
  createUsageRouter,
  GitHubClient,
} from '@sidequestteams/mission-control-sdk/backend';
import { SkynetClient } from '@sidequestteams/mission-control-sdk/skynet';
import { KPI_REGISTRY, getKpisForRolePacks } from '@sidequestteams/mission-control-sdk/kpis';

const PORT = process.env.MC_PORT ?? 4100;
const MANIFEST_PATH = process.env.RUNTIME_MANIFEST_PATH ?? resolve('./runtime-manifest.json');

// Load runtime manifest team block
const manifest = JSON.parse(readFileSync(MANIFEST_PATH, 'utf-8'));
const teamBlock = manifest.team;

// Initialize Skynet client from manifest connectivity
const skynetClient = new SkynetClient({
  wsUrl: teamBlock?.connectivity?.skynet?.ws_url ?? 'ws://skynet:8080',
  httpUrl: teamBlock?.connectivity?.skynet?.http_url ?? 'http://skynet:8080',
  authToken: process.env.SKYNET_OPS_TOKEN ?? process.env.OPENCLAW_GATEWAY_TOKEN,
});

// Initialize GitHub client from environment
const githubClient = new GitHubClient(
  process.env.GH_TOKEN ?? '',
  process.env.GITHUB_OWNER ?? '',
  process.env.GITHUB_REPO ?? '',
);

const app = express();
app.use(cors());
app.use(express.json());

app.get('/api/health', (_req, res) => {
  res.json({ ok: true });
});

// Serve manifest team block
app.get('/api/manifest', (_req, res) => {
  res.json({ team: teamBlock });
});

// ── Agents routes ──────────────────────────────────────────────────────
const agentsRouter = express.Router();
createAgentsRouter({
  async getAgents() {
    return skynetClient.httpGet('/agents');
  },
  async getAgent(id: string) {
    return skynetClient.httpGet(`/agents/${id}`);
  },
  async resetAgent(id: string) {
    return skynetClient.sendCommand({
      action: 'reset',
      agentId: id,
      timestamp: Date.now(),
    });
  },
})(agentsRouter);
app.use('/api/agents', agentsRouter);

// ── KPI routes ─────────────────────────────────────────────────────────
const kpisRouter = express.Router();
createKpisRouter({
  async getKpis(rolePacks) {
    const packs = rolePacks ?? teamBlock?.role_packs ?? [];
    const definitions = getKpisForRolePacks(packs);
    return definitions.map((d) => ({
      id: d.id,
      value: 0,
      freshness: 'mock' as const,
      source: 'sdk-default',
    }));
  },
  async getKpi(id: string) {
    const definition = KPI_REGISTRY.find((d) => d.id === id);
    if (!definition) return null;
    return { id, value: 0, freshness: 'mock' as const, source: 'sdk-default' };
  },
  getRegistry() {
    return KPI_REGISTRY;
  },
})(kpisRouter);
app.use('/api/productivity/kpis', kpisRouter);

// ── Telemetry routes ───────────────────────────────────────────────────
const telemetryRouter = express.Router();
createTelemetryRouter({
  async getOverallMetrics() {
    return skynetClient.httpGet('/metrics');
  },
  async getAgentTimeSeries(agentId: string, hours = 24) {
    return skynetClient.httpGet(`/agents/${agentId}/timeseries?hours=${hours}`);
  },
})(telemetryRouter);
app.use('/api/telemetry', telemetryRouter);

// ── Theme route ────────────────────────────────────────────────────────
const themeRouter = express.Router();
createThemeRouter({
  async getTeamBlock() {
    return teamBlock ?? null;
  },
})(themeRouter);
app.use('/api/theme', themeRouter);

// ── Tasks routes (GitHub API) ──────────────────────────────────────────
const tasksRouter = express.Router();
createTasksRouter({
  async getIssues(filters) {
    return githubClient.getIssues(filters);
  },
  async getPullRequests(state) {
    return githubClient.getPullRequests(state);
  },
  async getBoard() {
    return githubClient.getBoard();
  },
  async updateIssue(id, update) {
    return githubClient.updateIssue(id, update);
  },
})(tasksRouter);
app.use('/api/v4/tasks', tasksRouter);

// ── Activity routes (Skynet proxy) ─────────────────────────────────────
const activityRouter = express.Router();
createActivityRouter({
  async getActivity(limit) {
    const query = limit ? `?limit=${limit}` : '';
    return skynetClient.httpGet(`/activity${query}`);
  },
})(activityRouter);
app.use('/api/activity', activityRouter);

// ── Costs routes (Skynet proxy) ────────────────────────────────────────
const costsRouter = express.Router();
createCostsRouter({
  async getSummary(period) {
    return skynetClient.httpGet(`/costs/summary?period=${period ?? '24h'}`);
  },
  async getBreakdown() {
    return skynetClient.httpGet('/costs/breakdown');
  },
})(costsRouter);
app.use('/api/v4/costs', costsRouter);

// ── Usage routes (Skynet proxy) ────────────────────────────────────────
const usageRouter = express.Router();
createUsageRouter({
  async getUsage(period) {
    return skynetClient.httpGet(`/usage?period=${period ?? '24h'}`);
  },
})(usageRouter);
app.use('/api/usage', usageRouter);

// ── SSE proxy for Skynet events ────────────────────────────────────────
app.use('/api/events', createSkynetProxy(skynetClient));

// ── Start server with WebSocket support ────────────────────────────────
const server = createServer(app);

const wss = new WebSocketServer({ noServer: true });

server.on('upgrade', (request, socket, head) => {
  const pathname = new URL(request.url ?? '/', `http://${request.headers.host ?? 'localhost'}`).pathname;

  if (pathname !== '/ws') {
    socket.destroy();
    return;
  }

  wss.handleUpgrade(request, socket, head, (ws) => {
    wss.emit('connection', ws, request);
  });
});

wss.on('connection', () => {
  skynetClient.connect();
});

// Forward Skynet events to all connected WS clients
skynetClient.onEvent((event) => {
  const data = JSON.stringify(event);
  for (const client of wss.clients) {
    if (client.readyState === 1) {
      client.send(data);
    }
  }
});

// Heartbeat — keep WS connections alive
setInterval(() => {
  for (const client of wss.clients) {
    if (client.readyState === 1) client.ping();
  }
}, 30000);

server.listen(PORT, () => {
  console.log(`[{{teamSlug}}] Mission Control backend listening on :${PORT}`);
});
