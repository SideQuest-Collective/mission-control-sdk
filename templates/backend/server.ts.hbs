const PORT = process.env.MC_PORT ?? 4100;
const MANIFEST_PATH = process.env.RUNTIME_MANIFEST_PATH ?? resolve('./runtime-manifest.json');

// Load runtime manifest team block
const manifest = JSON.parse(readFileSync(MANIFEST_PATH, 'utf-8'));
const teamBlock = manifest.team;
const STATIC_KPI_IDS = new Set(KPI_REGISTRY.map((kpi) => kpi.id));

const manifestDynamicEntries: Array<{
  definition: KpiDefinition;
  pipeline: any;
  widgetDescriptor: TeamSpecificWidgetDescriptor;
}> = Array.isArray(teamBlock?.kpi_registry) && Array.isArray(teamBlock?.pipelines)
  ? teamBlock.kpi_registry.flatMap((entry: any, index: number) => {
      const pipeline = teamBlock.pipelines[index];
      if (!pipeline) {
        return [];
      }

      const widgetDescriptor = teamBlock?.widgets?.team_specific?.find((widget: any) => {
        return widget.id === String(entry.id).replace(/_/g, '-');
      }) ?? {
        id: String(entry.id).replace(/_/g, '-'),
        title: entry.name,
        primitive: entry.category === 'flow' || entry.category === 'capacity' ? 'sparkline' : 'stat-card',
        data_source: `kpi.${entry.category}.${entry.id}`,
        derived_from: 'bootstrap-llm',
        config: { unit: entry.unit, trend_window: pipeline.window },
        grid: { w: 3, h: 3 },
      };

      return [{
        definition: {
          id: entry.id,
          name: entry.name,
          category: entry.category,
          unit: entry.unit,
          description: entry.description,
          data_source: entry.scope === 'agent'
            ? `dynamic:${entry.agent_id ?? 'agent'}`
            : 'dynamic:team',
        },
        pipeline,
        widgetDescriptor,
      }];
    })
  : [];

// Initialize Skynet client from manifest connectivity
const skynetClient = new SkynetClient({
  wsUrl: teamBlock?.connectivity?.skynet?.ws_url ?? 'ws://skynet:8080',
  httpUrl: teamBlock?.connectivity?.skynet?.http_url ?? 'http://skynet:8080',
  authToken: process.env.SKYNET_OPS_TOKEN ?? process.env.OPENCLAW_GATEWAY_TOKEN,
});

// Initialize GitHub client from environment
const githubClient = new GitHubClient(
  process.env.GH_TOKEN ?? '',
  process.env.GITHUB_OWNER ?? '',
  process.env.GITHUB_REPO ?? '',
);

const kpiPool = new Pool({
  connectionString: process.env.KPI_DB_URL ?? process.env.HARNESS_DB_URL,
  max: 5,
  application_name: '{{teamSlug}}-kpi-store',
});
const kpiSchema = process.env.KPI_POSTGRES_SCHEMA ?? 'public';

const kpiStore = createKpiRuntimeStore(kpiPool, kpiSchema);
let projectionEngine: Awaited<ReturnType<typeof initKpiPipelineEngine>> | null = null;

function envKeyForAgentGatewayToken(agentId: string): string {
  return `OPENCLAW_GATEWAY_TOKEN_${agentId.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;
}

function parseBearerToken(req: any): string | null {
  const authHeader = req.headers?.authorization;
  if (typeof authHeader !== 'string' || !authHeader.startsWith('Bearer ')) {
    return null;
  }
  const token = authHeader.slice(7).trim();
  return token || null;
}

function resolveRequestActor(req: any): { id: string; type: 'agent' | 'operator' } | null {
  const token = parseBearerToken(req);
  if (!token) {
    return null;
  }

  const operatorToken = process.env.OPENCLAW_GATEWAY_TOKEN?.trim()
    || process.env.SKYNET_OPS_TOKEN?.trim()
    || '';
  if (operatorToken && token === operatorToken) {
    return { id: 'operator', type: 'operator' };
  }

  const claimedAgentId = typeof req.headers?.['x-agent-id'] === 'string'
    ? req.headers['x-agent-id'].trim()
    : '';
  if (!claimedAgentId) {
    return null;
  }

  const expectedAgentToken = process.env[envKeyForAgentGatewayToken(claimedAgentId)]?.trim() ?? '';
  if (!expectedAgentToken || token !== expectedAgentToken) {
    return null;
  }

  return { id: claimedAgentId, type: 'agent' };
}

function mergeKpiDefinitions(...groups: KpiDefinition[][]): KpiDefinition[] {
  const merged = new Map<string, KpiDefinition>();
  for (const group of groups) {
    for (const definition of group) {
      merged.set(definition.id, definition);
    }
  }
  return [...merged.values()];
}

function buildMockKpi(definition: KpiDefinition): KpiValue {
  return {
    id: definition.id,
    value: 0,
    freshness: 'mock',
    source: 'sdk-default',
  };
}

function filterDefinitionsForRolePacks(
  definitions: KpiDefinition[],
  rolePacks: string[],
): KpiDefinition[] {
  const allowedStaticIds = new Set(getKpisForRolePacks(rolePacks).map((definition) => definition.id));
  return definitions.filter((definition) => {
    return allowedStaticIds.has(definition.id) || !STATIC_KPI_IDS.has(definition.id);
  });
}

async function getRuntimeKpiDefinitions(): Promise<KpiDefinition[]> {
  const activeKpis = await kpiStore.listActive('{{teamSlug}}');
  return activeKpis.map((entry) => entry.kpi_definition);
}

async function getAllKpiDefinitions(): Promise<KpiDefinition[]> {
  return mergeKpiDefinitions(
    KPI_REGISTRY,
    await getRuntimeKpiDefinitions(),
  );
}

async function reconcileManifestDynamicKpis(): Promise<void> {
  const now = new Date().toISOString();

  for (const entry of manifestDynamicEntries) {
    const existingCatalog = await kpiStore.catalogGet('{{teamSlug}}', entry.definition.id);
    if (existingCatalog && existingCatalog.status !== 'active') {
      await kpiStore.deactivate('{{teamSlug}}', entry.definition.id);
      continue;
    }

    const activeKpi: ActiveKpi = {
      id: entry.definition.id,
      team_slug: '{{teamSlug}}',
      kpi_definition: entry.definition,
      pipeline: entry.pipeline,
      widget_descriptor: entry.widgetDescriptor,
      origin: 'bootstrap_llm',
      proposed_by: existingCatalog?.proposed_by,
      activated_at: existingCatalog?.last_active ?? now,
    };

    await kpiStore.activate(activeKpi);
    await kpiStore.catalogUpsert({
      id: entry.definition.id,
      team_slug: '{{teamSlug}}',
      kpi_definition: entry.definition,
      pipeline: entry.pipeline,
      origin: 'bootstrap_llm',
      proposed_by: existingCatalog?.proposed_by,
      first_registered: existingCatalog?.first_registered ?? now,
      last_active: now,
      times_bootstrapped: existingCatalog?.times_bootstrapped ?? 0,
      replaced_by: existingCatalog?.replaced_by,
      status: 'active',
    } satisfies KpiCatalogEntry);
  }
}

const app = express();
app.use(cors());
app.use(express.json());

app.get('/api/health', (_req, res) => {
  res.json({ ok: true });
});

// Serve manifest team block
app.get('/api/manifest', (_req, res) => {
  res.json({ team: teamBlock });
});

// ── Agents routes ──────────────────────────────────────────────────────
const agentsRouter = express.Router();
createAgentsRouter({
  async getAgents() {
    return skynetClient.httpGet('/agents');
  },
  async getAgent(id: string) {
    return skynetClient.httpGet(`/agents/${id}`);
  },
  async resetAgent(id: string) {
    return skynetClient.sendCommand({
      action: 'reset',
      agentId: id,
      timestamp: Date.now(),
    });
  },
})(agentsRouter);
app.use('/api/agents', agentsRouter);

// ── KPI routes ─────────────────────────────────────────────────────────
const kpisRouter = express.Router();
createKpisRouter({
  async getKpis(rolePacks) {
    const packs = rolePacks ?? teamBlock?.role_packs ?? [];
    const definitions = filterDefinitionsForRolePacks(await getAllKpiDefinitions(), packs);
    return definitions.map(buildMockKpi);
  },
  async getKpi(id: string) {
    const definition = (await getAllKpiDefinitions()).find((d) => d.id === id);
    if (!definition) return null;
    return buildMockKpi(definition);
  },
  async getRegistry() {
    return getAllKpiDefinitions();
  },
  get projectionEngine() {
    return projectionEngine ?? undefined;
  },
})(kpisRouter);
app.use('/api/productivity/kpis', kpisRouter);

