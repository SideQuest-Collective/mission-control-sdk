// ── KPI Proposals routes (runtime registration) ──────────────────────────
const kpiProposalsRouter = express.Router();
const skynetHttpUrl = teamBlock?.connectivity?.skynet?.http_url ?? 'http://skynet:8080';
const gatewayToken = process.env.SKYNET_OPS_TOKEN ?? process.env.OPENCLAW_GATEWAY_TOKEN ?? '';

function broadcastWsEvent(type: string, payload: Record<string, unknown>): void {
  const data = JSON.stringify({ type, payload });
  for (const client of wss.clients) {
    if (client.readyState === 1) {
      client.send(data);
    }
  }
}

createKpiProposalsRouter({
  store: kpiStore,
  teamSlug: '{{teamSlug}}',
  rosterSize: teamBlock?.roster?.length ?? 3,
  resolveActor: resolveRequestActor,
  onProposed(proposal) {
    emitKpiEvent(skynetClient, 'kpi.proposed', {
      proposal_id: proposal.id,
      kpi_name: proposal.proposal.kpi.name,
      proposed_by: proposal.proposal.proposed_by,
    });
    broadcastWsEvent('kpi.proposed', {
      proposal_id: proposal.id,
      kpi_name: proposal.proposal.kpi.name,
      proposed_by: proposal.proposal.proposed_by,
    });
    broadcastKpiProposal(proposal, skynetHttpUrl, gatewayToken).catch((err) =>
      console.error('[kpi-mesh] Broadcast failed:', err),
    );
  },
  onVoteReceived(vote) {
    emitKpiEvent(skynetClient, 'kpi.vote_received', vote);
    broadcastWsEvent('kpi.vote_received', vote);
  },
  onActivated(kpi) {
    projectionEngine?.register(kpi.kpi_definition, kpi.pipeline);
    emitKpiEvent(skynetClient, 'kpi.activated', {
      kpi_id: kpi.id,
      widget_descriptor: kpi.widget_descriptor,
    });
    broadcastWsEvent('kpi.activated', {
      kpi_id: kpi.id,
      widget_descriptor: kpi.widget_descriptor,
    });
  },
  onDeactivated(kpiId) {
    projectionEngine?.unregister(kpiId);
    emitKpiEvent(skynetClient, 'kpi.deactivated', { kpi_id: kpiId });
    broadcastWsEvent('kpi.deactivated', { kpi_id: kpiId });
  },
})(kpiProposalsRouter);
app.use('/api/kpis', kpiProposalsRouter);

// ── SSE proxy for Skynet events ────────────────────────────────────────
app.use('/api/events', createSkynetProxy(skynetClient));

// ── Start server with WebSocket support ────────────────────────────────
const server = createServer(app);

const wss = new WebSocketServer({ noServer: true });

server.on('upgrade', (request, socket, head) => {
  const pathname = new URL(request.url ?? '/', `http://${request.headers.host ?? 'localhost'}`).pathname;

  if (pathname !== '/ws') {
    socket.destroy();
    return;
  }

  wss.handleUpgrade(request, socket, head, (ws) => {
    wss.emit('connection', ws, request);
  });
});

wss.on('connection', () => {
  skynetClient.connect();
});

// Forward Skynet events to all connected WS clients
skynetClient.onEvent((event) => {
  const data = JSON.stringify(event);
  for (const client of wss.clients) {
    if (client.readyState === 1) {
      client.send(data);
    }
  }
});

// Heartbeat — keep WS connections alive
setInterval(() => {
  for (const client of wss.clients) {
    if (client.readyState === 1) client.ping();
  }
}, 30000);

async function bootstrapRuntime(): Promise<void> {
  await kpiPool.query(`CREATE SCHEMA IF NOT EXISTS ${kpiSchema}`);
  for (const stmt of buildKpiBootstrapStatements(kpiSchema)) {
    await kpiPool.query(stmt);
  }

  await reconcileManifestDynamicKpis();
  projectionEngine = await initKpiPipelineEngine(
    kpiStore,
    skynetClient,
    '{{teamSlug}}',
    KPI_REGISTRY,
    manifestDynamicEntries.map((entry) => ({
      definition: entry.definition,
      pipeline: entry.pipeline,
    })),
  );
}

bootstrapRuntime()
  .then(() => {
    server.listen(PORT, () => {
      console.log(`[{{teamSlug}}] Mission Control backend listening on :${PORT}`);
    });
  })
  .catch((err) => {
    console.error('[kpi-store] Bootstrap failed:', err);
    process.exitCode = 1;
  });
