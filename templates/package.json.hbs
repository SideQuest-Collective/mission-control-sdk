{
  "name": "@sidequestteams/{{teamSlug}}-mission-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev --hostname 0.0.0.0 --port 3001",
    "dev:backend": "tsx watch src/backend/index.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc --project tsconfig.backend.json",
    "build:frontend": "next build",
    "start": "node server.js",
    "start:backend": "node dist/index.js",
    "start:frontend": "node server.js",
    "lint": "next lint"
  },
  "dependencies": {
    "@sidequestteams/mission-control-sdk": "file:{{sdkDependencyPath}}",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
