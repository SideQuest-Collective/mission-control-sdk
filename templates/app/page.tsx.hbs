'use client';

import {
{{#each defaultWidgets}}
  {{component}},
{{/each}}
} from '@sidequestteams/mission-control-sdk/widgets';
import { DynamicWidget } from '@sidequestteams/mission-control-sdk/primitives';
import { useKpis, useManifest } from '@sidequestteams/mission-control-sdk/hooks';
import { useTheme } from '@sidequestteams/mission-control-sdk/theme';

const TEAM_SPECIFIC_WIDGETS = {{{json teamSpecificWidgets}}};
const GRID_SPAN_CLASS = {
  1: 'col-span-1',
  2: 'col-span-2',
  3: 'col-span-3',
  4: 'col-span-4',
  5: 'col-span-5',
  6: 'col-span-6',
  7: 'col-span-7',
  8: 'col-span-8',
  9: 'col-span-9',
  10: 'col-span-10',
  11: 'col-span-11',
  12: 'col-span-12',
} as const;

export default function Dashboard() {
  const { team, loading } = useManifest();
  const { kpis } = useKpis({ rolePacks: team?.role_packs });
  const { toggle, mode } = useTheme();

  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-screen">
        <p className="text-[var(--mc-text-secondary)]">Loading dashboard…</p>
      </div>
    );
  }

  return (
    <main className="min-h-screen bg-[var(--mc-background)] p-6">
      <header className="flex items-center justify-between mb-8">
        <div>
          <h1 className="text-2xl font-bold text-[var(--mc-text-primary)]">
            {{teamName}}
          </h1>
          <p className="text-sm text-[var(--mc-text-secondary)]">
            {{teamPurpose}}
          </p>
        </div>
        <button
          onClick={toggle}
          className="px-3 py-1.5 rounded-md bg-[var(--mc-surface)] text-[var(--mc-text-primary)] text-sm"
        >
          {mode === 'dark' ? '☀️' : '🌙'}
        </button>
      </header>

      <div className="grid grid-cols-12 gap-4 auto-rows-min">
        {/* Default widgets — pre-built, polished SDK components */}
{{#each defaultWidgets}}
        <div className="col-span-{{grid.w}}" style=\{{gridRow: 'span {{grid.h}}'}}>
          <{{component}} />
        </div>
{{/each}}

        {/* Team-specific widgets — driven by role packs, rendered via DynamicWidget */}
        {TEAM_SPECIFIC_WIDGETS.map((descriptor) => (
          <div
            key={descriptor.id}
            className={GRID_SPAN_CLASS[descriptor.grid.w as keyof typeof GRID_SPAN_CLASS] ?? 'col-span-12'}
            style=\{{gridRow: `span ${descriptor.grid.h}`}}
          >
            <DynamicWidget descriptor={descriptor} kpis={kpis} />
          </div>
        ))}
      </div>
    </main>
  );
}
