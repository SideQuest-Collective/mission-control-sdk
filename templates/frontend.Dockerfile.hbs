FROM node:22-alpine AS base
WORKDIR /workspace

FROM base AS deps
COPY mission-control-sdk ./mission-control-sdk
COPY {{generatedProjectPath}}/package*.json ./{{generatedProjectPath}}/
WORKDIR /workspace/{{generatedProjectPath}}
RUN npm ci 2>/dev/null || npm install

FROM deps AS build
ARG BACKEND_URL=http://localhost:3100
ENV BACKEND_URL=${BACKEND_URL}
ENV NEXT_TELEMETRY_DISABLED=1
COPY {{generatedProjectPath}}/src/ ./src/
COPY {{generatedProjectPath}}/next.config.js {{generatedProjectPath}}/tailwind.config.js {{generatedProjectPath}}/tsconfig.json {{generatedProjectPath}}/postcss.config.js ./
RUN mkdir -p public && npm run build:frontend

FROM node:22-alpine AS runtime
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3001
ENV HOSTNAME=0.0.0.0

COPY --from=build /workspace/{{generatedProjectPath}}/.next/standalone ./
COPY --from=build /workspace/{{generatedProjectPath}}/.next/static ./.next/static
COPY --from=build /workspace/{{generatedProjectPath}}/public ./public

EXPOSE 3001
CMD ["node", "server.js"]
