FROM node:22-alpine AS base
WORKDIR /workspace

FROM base AS deps
COPY mission-control-sdk ./mission-control-sdk
COPY {{generatedProjectPath}}/package*.json ./{{generatedProjectPath}}/
WORKDIR /workspace/{{generatedProjectPath}}
RUN npm ci 2>/dev/null || npm install

FROM base AS prod-deps
COPY mission-control-sdk ./mission-control-sdk
COPY {{generatedProjectPath}}/package*.json ./{{generatedProjectPath}}/
WORKDIR /workspace/{{generatedProjectPath}}
RUN npm ci --omit=dev 2>/dev/null || npm install --omit=dev

FROM deps AS build
COPY {{generatedProjectPath}}/src/backend/ ./src/backend/
COPY {{generatedProjectPath}}/tsconfig.backend.json ./
RUN npm run build:backend

FROM node:22-alpine AS runtime
WORKDIR /app

ENV NODE_ENV=production
ENV MC_PORT=3100
ENV MC_HOST=0.0.0.0

COPY --from=prod-deps /workspace/{{generatedProjectPath}}/node_modules ./node_modules
COPY --from=build /workspace/{{generatedProjectPath}}/dist ./dist
COPY --from=build /workspace/{{generatedProjectPath}}/package.json ./package.json

EXPOSE 3100
CMD ["node", "dist/index.js"]
